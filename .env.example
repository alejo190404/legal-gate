# LegalGate local development defaults
# Do not commit real Supabase, Render, Vercel, or WorkOS secrets.

# Gateway -> intake facade
LEGALGATE_BACKEND_URL=http://intake-orchestrator:8081
LEGALGATE_CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8080
GATEWAY_FORWARDED_TOKEN=local-dev-service-token

# Frontend build-time runtime config. Empty keeps local relative /api calls.
LEGALGATE_API_BASE_URL=

# Local Docker Compose Postgres
POSTGRES_DB=legalgate
POSTGRES_USER=legalgate
POSTGRES_PASSWORD=legalgate_dev_password

# Intake JDBC persistence. Production Render currently uses the Supabase pooler connection.
LEGALGATE_INTAKE_PERSISTENCE=jdbc
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/legalgate?sslmode=disable
SPRING_DATASOURCE_USERNAME=legalgate
SPRING_DATASOURCE_PASSWORD=legalgate_dev_password
SPRING_DATASOURCE_MAX_POOL_SIZE=5
SPRING_FLYWAY_ENABLED=true
LEGALGATE_SEED_DEMO_DATA=false

# Future WorkOS seam (not implemented in this milestone)
LEGALGATE_AUTH_MODE=PUBLIC_PROTOTYPE
WORKOS_ISSUER=
WORKOS_AUDIENCE=
WORKOS_JWKS_URL=

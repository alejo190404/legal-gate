# LegalGate local development defaults
# Do not commit real Supabase, Render, Vercel, or WorkOS secrets.

# Gateway -> intake facade
LEGALGATE_BACKEND_URL=http://intake-orchestrator:8081
LEGALGATE_CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8080
GATEWAY_FORWARDED_TOKEN=local-dev-service-token

# Frontend build-time runtime config. Empty keeps local relative /api calls.
LEGALGATE_API_BASE_URL=

# Local Docker Compose Postgres
POSTGRES_DB=legalgate
POSTGRES_USER=legalgate
POSTGRES_PASSWORD=legalgate_dev_password

# Intake JDBC persistence. Production Render currently uses the Supabase pooler connection.
LEGALGATE_INTAKE_PERSISTENCE=jdbc
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/legalgate?sslmode=disable
SPRING_DATASOURCE_USERNAME=legalgate
SPRING_DATASOURCE_PASSWORD=legalgate_dev_password
SPRING_DATASOURCE_MAX_POOL_SIZE=5
SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_VALIDATE_ON_MIGRATE=false
LEGALGATE_SEED_DEMO_DATA=false
LEGALGATE_INTAKE_EMAIL_DOMAIN=intake.legal-gate.co
LEGALGATE_CONSULTATION_CLASSIFIER_URL=http://consultation-classifier:8083
LEGALGATE_CONSULTATION_CLASSIFIER_TIMEOUT=3s
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_TEMPERATURE=0.2
CLASSIFIER_LOG_PAYLOADS=false
CLASSIFIER_LOG_PREVIEW_CHARS=500

# Mail Ingress -> Intake Orchestrator synchronous handoff
LEGALGATE_INTAKE_ORCHESTRATOR_URL=http://intake-orchestrator:8081

# CloudMailin -> mail-ingress Basic Auth for local webhook testing
LEGALGATE_CLOUDMAILIN_USERNAME=cloudmailin-local
LEGALGATE_CLOUDMAILIN_PASSWORD=cloudmailin-local-password
LEGALGATE_OUTBOUND_EMAIL_ENABLED=false
LEGALGATE_CLOUDMAILIN_SMTP_USERNAME=
LEGALGATE_CLOUDMAILIN_API_TOKEN=
LEGALGATE_NOTIFICATIONS_FROM_EMAIL=agenda@legal-gate.co
LEGALGATE_NOTIFICATIONS_FROM_NAME=LegalGate Agenda
LEGALGATE_OUTBOUND_TEST_MODE=true

# MailerSend -> mail-ingress webhook verification for local webhook testing
LEGALGATE_MAILERSEND_WEBHOOK_SECRET=mailersend-local-secret

# Future WorkOS seam (not implemented in this milestone)
LEGALGATE_AUTH_MODE=PUBLIC_PROTOTYPE
WORKOS_ISSUER=
WORKOS_AUDIENCE=
WORKOS_JWKS_URL=

{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci --prefix services/frontend",
  "buildCommand": "npm run build --prefix services/frontend",
  "outputDirectory": "services/frontend/dist/frontend/browser",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
